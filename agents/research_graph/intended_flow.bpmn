<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_research_graph_intended"
    targetNamespace="http://tmls2026/research-graph">

  <bpmn:process id="research_graph_intended"
                name="research_graph — intended per-turn flow"
                isExecutable="false">

    <bpmn:documentation>
      Intended per-turn flow for the research_graph agent. Unlike the
      research_react BPMN, both the GRAPH NODES (classify, search, browse,
      web, deep, synth) AND the TOOLS they invoke (find_similar_articles,
      sample_articles, web_search, analyze_full_article) appear as
      activities. Each tool-bearing node maps to two consecutive activities
      in the trace: the node's agent execution, then the tool call it
      issues. The classify and synth nodes have no tools, so they each
      contribute a single activity.

      Activity names match the span names emitted by Strands' OTel
      instrumentation (for nodes) and the @tool decorator (for tools), so
      the XES log produced by process_mining/xray_to_xes.py uses these
      names directly — no remapping required.
    </bpmn:documentation>

    <!-- ===== Start ===== -->
    <bpmn:startEvent id="start" name="User message received">
      <bpmn:outgoing>flow_start_to_classify</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ===== classify NODE (always runs first) ===== -->
    <bpmn:task id="node_classify" name="classify">
      <bpmn:documentation>Graph node: LLM agent (no tools) that reads the
        user's message + conversation history and emits a single JSON object
        with `intent` and extracted parameters. The intent value drives the
        outgoing edges from gw_intent.</bpmn:documentation>
      <bpmn:incoming>flow_start_to_classify</bpmn:incoming>
      <bpmn:outgoing>flow_classify_to_intent</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_intent" name="Route on intent">
      <bpmn:incoming>flow_classify_to_intent</bpmn:incoming>
      <bpmn:outgoing>flow_intent_search</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_browse</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_web</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_deep</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_decline</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== search branch ===== -->
    <bpmn:task id="node_search" name="search">
      <bpmn:documentation>Graph node: tool-bound LLM agent. Receives the
        classifier JSON, calls find_similar_articles exactly once with the
        query/categories/dates from it, returns the tool result.</bpmn:documentation>
      <bpmn:incoming>flow_intent_search</bpmn:incoming>
      <bpmn:outgoing>flow_search_to_tool</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="tool_find_similar_articles" name="find_similar_articles">
      <bpmn:documentation>Tool: hybrid retrieval over the arXiv KB
        (wraps strands_tools.retrieve).</bpmn:documentation>
      <bpmn:incoming>flow_search_to_tool</bpmn:incoming>
      <bpmn:outgoing>flow_after_find_similar</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== browse branch ===== -->
    <bpmn:task id="node_browse" name="browse">
      <bpmn:documentation>Graph node: tool-bound LLM agent. Calls
        sample_articles with the count + optional filters from the classifier.</bpmn:documentation>
      <bpmn:incoming>flow_intent_browse</bpmn:incoming>
      <bpmn:outgoing>flow_browse_to_tool</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="tool_sample_articles" name="sample_articles">
      <bpmn:documentation>Tool: random sample via direct OpenSearch DSL.</bpmn:documentation>
      <bpmn:incoming>flow_browse_to_tool</bpmn:incoming>
      <bpmn:outgoing>flow_after_sample_articles</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== web branch ===== -->
    <bpmn:task id="node_web" name="web">
      <bpmn:documentation>Graph node: tool-bound LLM agent. Calls web_search
        with the query from the classifier.</bpmn:documentation>
      <bpmn:incoming>flow_intent_web</bpmn:incoming>
      <bpmn:outgoing>flow_web_to_tool</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="tool_web_search" name="web_search">
      <bpmn:documentation>Tool: DuckDuckGo search.</bpmn:documentation>
      <bpmn:incoming>flow_web_to_tool</bpmn:incoming>
      <bpmn:outgoing>flow_after_web_search</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== deep branch (only reachable when classifier intent=deep,
         which itself requires a prior assistant offer + user "yes") ===== -->
    <bpmn:task id="node_deep" name="deep">
      <bpmn:documentation>Graph node: tool-bound LLM agent. Calls
        analyze_full_article with arxiv_id and user_confirmed=True.
        Reachable only via the deep-confirmed routing decision in
        classify; the tool's runtime user_confirmed guard is a safety net.</bpmn:documentation>
      <bpmn:incoming>flow_intent_deep</bpmn:incoming>
      <bpmn:outgoing>flow_deep_to_tool</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="tool_analyze_full_article" name="analyze_full_article">
      <bpmn:documentation>Tool: download arXiv PDF and run an extended
        summary. EXPENSIVE.</bpmn:documentation>
      <bpmn:incoming>flow_deep_to_tool</bpmn:incoming>
      <bpmn:outgoing>flow_after_analyze_full</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== Join + synth + end ===== -->
    <bpmn:exclusiveGateway id="gw_join" name="Converge">
      <bpmn:incoming>flow_after_find_similar</bpmn:incoming>
      <bpmn:incoming>flow_after_sample_articles</bpmn:incoming>
      <bpmn:incoming>flow_after_web_search</bpmn:incoming>
      <bpmn:incoming>flow_after_analyze_full</bpmn:incoming>
      <bpmn:incoming>flow_intent_decline</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_synth</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="node_synth" name="synth">
      <bpmn:documentation>Graph node: LLM agent (no tools). Reads the prior
        node's output + conversation history and composes the user-facing
        reply. May append a deep-analysis consent question.</bpmn:documentation>
      <bpmn:incoming>flow_join_to_synth</bpmn:incoming>
      <bpmn:outgoing>flow_synth_to_end</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end" name="Response delivered">
      <bpmn:incoming>flow_synth_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== Sequence flows ===== -->
    <bpmn:sequenceFlow id="flow_start_to_classify" sourceRef="start"          targetRef="node_classify" />
    <bpmn:sequenceFlow id="flow_classify_to_intent" sourceRef="node_classify" targetRef="gw_intent" />

    <bpmn:sequenceFlow id="flow_intent_search"  name="intent=search"
                       sourceRef="gw_intent" targetRef="node_search" />
    <bpmn:sequenceFlow id="flow_intent_browse"  name="intent=browse"
                       sourceRef="gw_intent" targetRef="node_browse" />
    <bpmn:sequenceFlow id="flow_intent_web"     name="intent=web"
                       sourceRef="gw_intent" targetRef="node_web" />
    <bpmn:sequenceFlow id="flow_intent_deep"    name="intent=deep (consent confirmed)"
                       sourceRef="gw_intent" targetRef="node_deep" />
    <bpmn:sequenceFlow id="flow_intent_decline" name="intent=decline / invalid"
                       sourceRef="gw_intent" targetRef="gw_join" />

    <bpmn:sequenceFlow id="flow_search_to_tool" sourceRef="node_search" targetRef="tool_find_similar_articles" />
    <bpmn:sequenceFlow id="flow_browse_to_tool" sourceRef="node_browse" targetRef="tool_sample_articles" />
    <bpmn:sequenceFlow id="flow_web_to_tool"    sourceRef="node_web"    targetRef="tool_web_search" />
    <bpmn:sequenceFlow id="flow_deep_to_tool"   sourceRef="node_deep"   targetRef="tool_analyze_full_article" />

    <bpmn:sequenceFlow id="flow_after_find_similar"   sourceRef="tool_find_similar_articles" targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_after_sample_articles" sourceRef="tool_sample_articles"      targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_after_web_search"     sourceRef="tool_web_search"           targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_after_analyze_full"   sourceRef="tool_analyze_full_article" targetRef="gw_join" />

    <bpmn:sequenceFlow id="flow_join_to_synth" sourceRef="gw_join"    targetRef="node_synth" />
    <bpmn:sequenceFlow id="flow_synth_to_end"  sourceRef="node_synth" targetRef="end" />

  </bpmn:process>

  <!-- BPMN DI: minimal vertical layout (5 branches stacked). Auto-layout
       in your modeler will tidy this. -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane id="plane_1" bpmnElement="research_graph_intended">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="80" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_node_classify" bpmnElement="node_classify">
        <dc:Bounds x="160" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_intent" bpmnElement="gw_intent" isMarkerVisible="true">
        <dc:Bounds x="320" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- search row (top) -->
      <bpmndi:BPMNShape id="shape_node_search" bpmnElement="node_search">
        <dc:Bounds x="430" y="40" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_tool_find_similar" bpmnElement="tool_find_similar_articles">
        <dc:Bounds x="600" y="40" width="160" height="80" />
      </bpmndi:BPMNShape>

      <!-- browse row -->
      <bpmndi:BPMNShape id="shape_node_browse" bpmnElement="node_browse">
        <dc:Bounds x="430" y="160" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_tool_sample_articles" bpmnElement="tool_sample_articles">
        <dc:Bounds x="600" y="160" width="160" height="80" />
      </bpmndi:BPMNShape>

      <!-- web row -->
      <bpmndi:BPMNShape id="shape_node_web" bpmnElement="node_web">
        <dc:Bounds x="430" y="280" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_tool_web_search" bpmnElement="tool_web_search">
        <dc:Bounds x="600" y="280" width="160" height="80" />
      </bpmndi:BPMNShape>

      <!-- deep row -->
      <bpmndi:BPMNShape id="shape_node_deep" bpmnElement="node_deep">
        <dc:Bounds x="430" y="520" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_tool_analyze_full" bpmnElement="tool_analyze_full_article">
        <dc:Bounds x="600" y="520" width="160" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_gw_join" bpmnElement="gw_join" isMarkerVisible="true">
        <dc:Bounds x="820" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_node_synth" bpmnElement="node_synth">
        <dc:Bounds x="920" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end" bpmnElement="end">
        <dc:Bounds x="1080" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_flow_start_to_classify" bpmnElement="flow_start_to_classify">
        <di:waypoint x="116" y="380" />
        <di:waypoint x="160" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_classify_to_intent" bpmnElement="flow_classify_to_intent">
        <di:waypoint x="280" y="380" />
        <di:waypoint x="320" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_intent_search" bpmnElement="flow_intent_search">
        <di:waypoint x="345" y="355" />
        <di:waypoint x="345" y="80" />
        <di:waypoint x="430" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_browse" bpmnElement="flow_intent_browse">
        <di:waypoint x="345" y="355" />
        <di:waypoint x="345" y="200" />
        <di:waypoint x="430" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_web" bpmnElement="flow_intent_web">
        <di:waypoint x="345" y="355" />
        <di:waypoint x="345" y="320" />
        <di:waypoint x="430" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_deep" bpmnElement="flow_intent_deep">
        <di:waypoint x="345" y="405" />
        <di:waypoint x="345" y="560" />
        <di:waypoint x="430" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_decline" bpmnElement="flow_intent_decline">
        <di:waypoint x="370" y="380" />
        <di:waypoint x="820" y="380" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_search_to_tool" bpmnElement="flow_search_to_tool">
        <di:waypoint x="550" y="80" /><di:waypoint x="600" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_browse_to_tool" bpmnElement="flow_browse_to_tool">
        <di:waypoint x="550" y="200" /><di:waypoint x="600" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_web_to_tool" bpmnElement="flow_web_to_tool">
        <di:waypoint x="550" y="320" /><di:waypoint x="600" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_deep_to_tool" bpmnElement="flow_deep_to_tool">
        <di:waypoint x="550" y="560" /><di:waypoint x="600" y="560" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_after_find_similar" bpmnElement="flow_after_find_similar">
        <di:waypoint x="760" y="80" />
        <di:waypoint x="845" y="80" />
        <di:waypoint x="845" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_sample_articles" bpmnElement="flow_after_sample_articles">
        <di:waypoint x="760" y="200" />
        <di:waypoint x="845" y="200" />
        <di:waypoint x="845" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_web_search" bpmnElement="flow_after_web_search">
        <di:waypoint x="760" y="320" />
        <di:waypoint x="820" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_analyze_full" bpmnElement="flow_after_analyze_full">
        <di:waypoint x="760" y="560" />
        <di:waypoint x="845" y="560" />
        <di:waypoint x="845" y="405" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_join_to_synth" bpmnElement="flow_join_to_synth">
        <di:waypoint x="870" y="380" /><di:waypoint x="920" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_synth_to_end" bpmnElement="flow_synth_to_end">
        <di:waypoint x="1040" y="380" /><di:waypoint x="1080" y="380" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
