<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_trusteeship_intended" targetNamespace="http://tmls2026/trusteeship" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="trusteeship_intended" name="Trusteeship application — three-phase intended flow" isExecutable="false">
    <bpmn:documentation>
      Three-phase trusteeship-application flow:

        Phase 1 (linear):
          Start (TrusteeshipRequested) → CreateApplication →
          assess_initial_state.

        Phase 2 (event loop, conditional):
          Skipped if `application` AND `medical` are already complete after
          the initial assessment. Otherwise: wait for ApplicationUpdate or
          MedicalUpdate; AI assesses the corresponding item; check if both
          are now complete; loop back if not.

        Phase 3 (event loop, conditional):
          Skipped if `credit_check` AND `criminal_check` AND
          `personal_references` are already complete by the time Phase 2
          finishes (or is skipped). Otherwise: wait for any of three update
          events; AI assesses the corresponding item; check if all three
          are now complete; loop back if not.

        Terminal:
          mark_ready_for_court → ReadyForCourt.

      Activity names match the OTel span names the agent emits. The five
      assess_* names + mark_ready_for_court + reject_application come from
      @tool decoration. CreateApplication is the one manually-instrumented
      entrypoint span.

      Each external event arrives as a separate AgentCore invocation /
      X-Ray trace. End-to-end conformance requires assembling traces by
      application_id (future work in xray_to_xes.py — currently uses
      X-Ray trace id as the case id).
    </bpmn:documentation>
    <bpmn:startEvent id="start" name="TrusteeshipRequested">
      <bpmn:outgoing>flow_start_to_create</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_assess_initial_state" name="assess_initial_state">
      <bpmn:incoming>flow_start_to_create</bpmn:incoming>
      <bpmn:outgoing>flow_initial_assess_to_gw2_skip</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_skip_phase2" name="App + Medical already complete?" default="flow_skip2_no_to_wait2">
      <bpmn:incoming>flow_initial_assess_to_gw2_skip</bpmn:incoming>
      <bpmn:outgoing>flow_skip2_no_to_wait2</bpmn:outgoing>
      <bpmn:outgoing>Flow_0ipyage</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:eventBasedGateway id="gw_phase2_wait" name="Wait for application/medical event">
      <bpmn:incoming>flow_skip2_no_to_wait2</bpmn:incoming>
      <bpmn:incoming>flow_continue2_no_loop</bpmn:incoming>
      <bpmn:outgoing>flow_wait2_to_app_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait2_to_med_update</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="event_application_update" name="ApplicationUpdate">
      <bpmn:incoming>flow_wait2_to_app_update</bpmn:incoming>
      <bpmn:outgoing>flow_app_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_medical_update" name="MedicalUpdate">
      <bpmn:incoming>flow_wait2_to_med_update</bpmn:incoming>
      <bpmn:outgoing>flow_med_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_assess_application" name="assess_application">
      <bpmn:incoming>flow_app_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>Flow_00n6h9p</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_medical" name="assess_medical">
      <bpmn:incoming>flow_med_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>Flow_1ofwpdi</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_phase2_continue" name="App + Medical now complete?" default="flow_continue2_no_loop">
      <bpmn:incoming>Flow_1ofwpdi</bpmn:incoming>
      <bpmn:incoming>Flow_00n6h9p</bpmn:incoming>
      <bpmn:outgoing>flow_continue2_no_loop</bpmn:outgoing>
      <bpmn:outgoing>Flow_1kewc5g</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gw_skip_phase3" name="CCP already complete?" default="flow_skip3_no_to_wait3">
      <bpmn:incoming>Flow_0ipyage</bpmn:incoming>
      <bpmn:incoming>Flow_1kewc5g</bpmn:incoming>
      <bpmn:outgoing>flow_skip3_no_to_wait3</bpmn:outgoing>
      <bpmn:outgoing>Flow_06tpq93</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:eventBasedGateway id="gw_phase3_wait" name="Wait for background-check event">
      <bpmn:incoming>flow_skip3_no_to_wait3</bpmn:incoming>
      <bpmn:incoming>Flow_0y9wfjz</bpmn:incoming>
      <bpmn:outgoing>flow_wait3_to_credit_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait3_to_criminal_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait3_to_refs_update</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="event_credit_check_update" name="CreditCheckUpdate">
      <bpmn:incoming>flow_wait3_to_credit_update</bpmn:incoming>
      <bpmn:outgoing>Flow_04d8o1q</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_criminal_check_update" name="CriminalCheckUpdate">
      <bpmn:incoming>flow_wait3_to_criminal_update</bpmn:incoming>
      <bpmn:outgoing>flow_criminal_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_personal_references_update" name="PersonalReferencesUpdate">
      <bpmn:incoming>flow_wait3_to_refs_update</bpmn:incoming>
      <bpmn:outgoing>flow_refs_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_assess_credit_check" name="assess_credit_check">
      <bpmn:incoming>Flow_04d8o1q</bpmn:incoming>
      <bpmn:outgoing>flow_assess_credit_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_criminal_check" name="assess_criminal_check">
      <bpmn:incoming>flow_criminal_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_criminal_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_personal_references" name="assess_personal_references">
      <bpmn:incoming>flow_refs_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_refs_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_phase3_continue" name="All 3 checks now complete?" default="Flow_0y9wfjz">
      <bpmn:incoming>flow_assess_credit_to_continue3</bpmn:incoming>
      <bpmn:incoming>flow_assess_criminal_to_continue3</bpmn:incoming>
      <bpmn:incoming>flow_assess_refs_to_continue3</bpmn:incoming>
      <bpmn:outgoing>Flow_19c5zm9</bpmn:outgoing>
      <bpmn:outgoing>Flow_0y9wfjz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_mark_ready_for_court" name="mark_ready_for_court">
      <bpmn:incoming>Flow_06tpq93</bpmn:incoming>
      <bpmn:incoming>Flow_19c5zm9</bpmn:incoming>
      <bpmn:outgoing>flow_ready_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end" name="ReadyForCourt">
      <bpmn:incoming>flow_ready_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_create" sourceRef="start" targetRef="task_assess_initial_state" />
    <bpmn:sequenceFlow id="flow_initial_assess_to_gw2_skip" sourceRef="task_assess_initial_state" targetRef="gw_skip_phase2" />
    <bpmn:sequenceFlow id="flow_skip2_no_to_wait2" sourceRef="gw_skip_phase2" targetRef="gw_phase2_wait" />
    <bpmn:sequenceFlow id="flow_wait2_to_app_update" sourceRef="gw_phase2_wait" targetRef="event_application_update" />
    <bpmn:sequenceFlow id="flow_wait2_to_med_update" sourceRef="gw_phase2_wait" targetRef="event_medical_update" />
    <bpmn:sequenceFlow id="flow_app_update_to_assess" sourceRef="event_application_update" targetRef="task_assess_application" />
    <bpmn:sequenceFlow id="flow_med_update_to_assess" sourceRef="event_medical_update" targetRef="task_assess_medical" />
    <bpmn:sequenceFlow id="flow_continue2_no_loop" sourceRef="gw_phase2_continue" targetRef="gw_phase2_wait" />
    <bpmn:sequenceFlow id="flow_skip3_no_to_wait3" sourceRef="gw_skip_phase3" targetRef="gw_phase3_wait" />
    <bpmn:sequenceFlow id="flow_wait3_to_credit_update" sourceRef="gw_phase3_wait" targetRef="event_credit_check_update" />
    <bpmn:sequenceFlow id="flow_wait3_to_criminal_update" sourceRef="gw_phase3_wait" targetRef="event_criminal_check_update" />
    <bpmn:sequenceFlow id="flow_wait3_to_refs_update" sourceRef="gw_phase3_wait" targetRef="event_personal_references_update" />
    <bpmn:sequenceFlow id="flow_criminal_update_to_assess" sourceRef="event_criminal_check_update" targetRef="task_assess_criminal_check" />
    <bpmn:sequenceFlow id="flow_refs_update_to_assess" sourceRef="event_personal_references_update" targetRef="task_assess_personal_references" />
    <bpmn:sequenceFlow id="flow_assess_credit_to_continue3" sourceRef="task_assess_credit_check" targetRef="gw_phase3_continue" />
    <bpmn:sequenceFlow id="flow_assess_criminal_to_continue3" sourceRef="task_assess_criminal_check" targetRef="gw_phase3_continue" />
    <bpmn:sequenceFlow id="flow_assess_refs_to_continue3" sourceRef="task_assess_personal_references" targetRef="gw_phase3_continue" />
    <bpmn:sequenceFlow id="flow_ready_to_end" sourceRef="task_mark_ready_for_court" targetRef="end" />
    <bpmn:sequenceFlow id="Flow_1ofwpdi" sourceRef="task_assess_medical" targetRef="gw_phase2_continue" />
    <bpmn:sequenceFlow id="Flow_00n6h9p" sourceRef="task_assess_application" targetRef="gw_phase2_continue" />
    <bpmn:sequenceFlow id="Flow_0ipyage" sourceRef="gw_skip_phase2" targetRef="gw_skip_phase3" />
    <bpmn:sequenceFlow id="Flow_1kewc5g" sourceRef="gw_phase2_continue" targetRef="gw_skip_phase3" />
    <bpmn:sequenceFlow id="Flow_04d8o1q" sourceRef="event_credit_check_update" targetRef="task_assess_credit_check" />
    <bpmn:sequenceFlow id="Flow_06tpq93" sourceRef="gw_skip_phase3" targetRef="task_mark_ready_for_court" />
    <bpmn:sequenceFlow id="Flow_19c5zm9" sourceRef="gw_phase3_continue" targetRef="task_mark_ready_for_court" />
    <bpmn:sequenceFlow id="Flow_0y9wfjz" sourceRef="gw_phase3_continue" targetRef="gw_phase3_wait" />
  </bpmn:process>
