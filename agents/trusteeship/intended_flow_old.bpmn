<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_trusteeship_intended"
    targetNamespace="http://tmls2026/trusteeship">

  <bpmn:process id="trusteeship_intended"
                name="Trusteeship application — three-phase intended flow"
                isExecutable="false">

    <bpmn:documentation>
      Three-phase trusteeship-application flow:

        Phase 1 (linear):
          Start (TrusteeshipRequested) → CreateApplication →
          assess_initial_state.

        Phase 2 (event loop, conditional):
          Skipped if `application` AND `medical` are already complete after
          the initial assessment. Otherwise: wait for ApplicationUpdate or
          MedicalUpdate; AI assesses the corresponding item; check if both
          are now complete; loop back if not.

        Phase 3 (event loop, conditional):
          Skipped if `credit_check` AND `criminal_check` AND
          `personal_references` are already complete by the time Phase 2
          finishes (or is skipped). Otherwise: wait for any of three update
          events; AI assesses the corresponding item; check if all three
          are now complete; loop back if not.

        Terminal:
          mark_ready_for_court → ReadyForCourt.

      Activity names match the OTel span names the agent emits. The five
      assess_* names + mark_ready_for_court + reject_application come from
      @tool decoration. CreateApplication is the one manually-instrumented
      entrypoint span.

      Each external event arrives as a separate AgentCore invocation /
      X-Ray trace. End-to-end conformance requires assembling traces by
      application_id (future work in xray_to_xes.py — currently uses
      X-Ray trace id as the case id).
    </bpmn:documentation>

    <!-- ===== Phase 1 (linear) ===== -->
    <bpmn:startEvent id="start" name="TrusteeshipRequested">
      <bpmn:outgoing>flow_start_to_create</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <bpmn:serviceTask id="task_create_application" name="CreateApplication">
      <bpmn:incoming>flow_start_to_create</bpmn:incoming>
      <bpmn:outgoing>flow_create_to_initial_assess</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_assess_initial_state" name="assess_initial_state">
      <bpmn:incoming>flow_create_to_initial_assess</bpmn:incoming>
      <bpmn:outgoing>flow_initial_assess_to_gw2_skip</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="gw_skip_phase2" name="App + Medical already complete?">
      <bpmn:incoming>flow_initial_assess_to_gw2_skip</bpmn:incoming>
      <bpmn:outgoing>flow_skip2_yes_to_gw3_skip</bpmn:outgoing>
      <bpmn:outgoing>flow_skip2_no_to_wait2</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== Phase 2 (event loop) ===== -->
    <bpmn:eventBasedGateway id="gw_phase2_wait" name="Wait for application/medical event">
      <bpmn:incoming>flow_skip2_no_to_wait2</bpmn:incoming>
      <bpmn:incoming>flow_continue2_no_loop</bpmn:incoming>
      <bpmn:outgoing>flow_wait2_to_app_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait2_to_med_update</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="event_application_update" name="ApplicationUpdate">
      <bpmn:incoming>flow_wait2_to_app_update</bpmn:incoming>
      <bpmn:outgoing>flow_app_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_medical_update" name="MedicalUpdate">
      <bpmn:incoming>flow_wait2_to_med_update</bpmn:incoming>
      <bpmn:outgoing>flow_med_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="task_assess_application" name="assess_application">
      <bpmn:incoming>flow_app_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_app_to_continue2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_medical" name="assess_medical">
      <bpmn:incoming>flow_med_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_med_to_continue2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="gw_phase2_continue" name="App + Medical now complete?">
      <bpmn:incoming>flow_assess_app_to_continue2</bpmn:incoming>
      <bpmn:incoming>flow_assess_med_to_continue2</bpmn:incoming>
      <bpmn:outgoing>flow_continue2_no_loop</bpmn:outgoing>
      <bpmn:outgoing>flow_continue2_yes_to_gw3_skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== Phase 3 skip-or-enter gateway ===== -->
    <bpmn:exclusiveGateway id="gw_skip_phase3" name="All 3 checks already complete?">
      <bpmn:incoming>flow_skip2_yes_to_gw3_skip</bpmn:incoming>
      <bpmn:incoming>flow_continue2_yes_to_gw3_skip</bpmn:incoming>
      <bpmn:outgoing>flow_skip3_yes_to_ready</bpmn:outgoing>
      <bpmn:outgoing>flow_skip3_no_to_wait3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== Phase 3 (event loop) ===== -->
    <bpmn:eventBasedGateway id="gw_phase3_wait" name="Wait for background-check event">
      <bpmn:incoming>flow_skip3_no_to_wait3</bpmn:incoming>
      <bpmn:incoming>flow_continue3_no_loop</bpmn:incoming>
      <bpmn:outgoing>flow_wait3_to_credit_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait3_to_criminal_update</bpmn:outgoing>
      <bpmn:outgoing>flow_wait3_to_refs_update</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <bpmn:intermediateCatchEvent id="event_credit_check_update" name="CreditCheckUpdate">
      <bpmn:incoming>flow_wait3_to_credit_update</bpmn:incoming>
      <bpmn:outgoing>flow_credit_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_criminal_check_update" name="CriminalCheckUpdate">
      <bpmn:incoming>flow_wait3_to_criminal_update</bpmn:incoming>
      <bpmn:outgoing>flow_criminal_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_personal_references_update" name="PersonalReferencesUpdate">
      <bpmn:incoming>flow_wait3_to_refs_update</bpmn:incoming>
      <bpmn:outgoing>flow_refs_update_to_assess</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>

    <bpmn:serviceTask id="task_assess_credit_check" name="assess_credit_check">
      <bpmn:incoming>flow_credit_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_credit_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_criminal_check" name="assess_criminal_check">
      <bpmn:incoming>flow_criminal_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_criminal_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_assess_personal_references" name="assess_personal_references">
      <bpmn:incoming>flow_refs_update_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_refs_to_continue3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="gw_phase3_continue" name="All 3 checks now complete?">
      <bpmn:incoming>flow_assess_credit_to_continue3</bpmn:incoming>
      <bpmn:incoming>flow_assess_criminal_to_continue3</bpmn:incoming>
      <bpmn:incoming>flow_assess_refs_to_continue3</bpmn:incoming>
      <bpmn:outgoing>flow_continue3_no_loop</bpmn:outgoing>
      <bpmn:outgoing>flow_continue3_yes_to_ready</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== Terminal ===== -->
    <bpmn:serviceTask id="task_mark_ready_for_court" name="mark_ready_for_court">
      <bpmn:incoming>flow_skip3_yes_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_continue3_yes_to_ready</bpmn:incoming>
      <bpmn:outgoing>flow_ready_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end" name="ReadyForCourt">
      <bpmn:incoming>flow_ready_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== Sequence flows ===== -->
    <bpmn:sequenceFlow id="flow_start_to_create"        sourceRef="start"                              targetRef="task_create_application" />
    <bpmn:sequenceFlow id="flow_create_to_initial_assess" sourceRef="task_create_application"         targetRef="task_assess_initial_state" />
    <bpmn:sequenceFlow id="flow_initial_assess_to_gw2_skip" sourceRef="task_assess_initial_state"     targetRef="gw_skip_phase2" />

    <bpmn:sequenceFlow id="flow_skip2_yes_to_gw3_skip"  name="yes — skip"
                       sourceRef="gw_skip_phase2"   targetRef="gw_skip_phase3" />
    <bpmn:sequenceFlow id="flow_skip2_no_to_wait2"      name="no — enter loop"
                       sourceRef="gw_skip_phase2"   targetRef="gw_phase2_wait" />

    <bpmn:sequenceFlow id="flow_wait2_to_app_update"    sourceRef="gw_phase2_wait" targetRef="event_application_update" />
    <bpmn:sequenceFlow id="flow_wait2_to_med_update"    sourceRef="gw_phase2_wait" targetRef="event_medical_update" />
    <bpmn:sequenceFlow id="flow_app_update_to_assess"   sourceRef="event_application_update" targetRef="task_assess_application" />
    <bpmn:sequenceFlow id="flow_med_update_to_assess"   sourceRef="event_medical_update"     targetRef="task_assess_medical" />
    <bpmn:sequenceFlow id="flow_assess_app_to_continue2" sourceRef="task_assess_application" targetRef="gw_phase2_continue" />
    <bpmn:sequenceFlow id="flow_assess_med_to_continue2" sourceRef="task_assess_medical"     targetRef="gw_phase2_continue" />

    <bpmn:sequenceFlow id="flow_continue2_no_loop"      name="not yet — loop back"
                       sourceRef="gw_phase2_continue" targetRef="gw_phase2_wait" />
    <bpmn:sequenceFlow id="flow_continue2_yes_to_gw3_skip" name="both complete"
                       sourceRef="gw_phase2_continue" targetRef="gw_skip_phase3" />

    <bpmn:sequenceFlow id="flow_skip3_yes_to_ready"     name="yes — skip"
                       sourceRef="gw_skip_phase3"   targetRef="task_mark_ready_for_court" />
    <bpmn:sequenceFlow id="flow_skip3_no_to_wait3"      name="no — enter loop"
                       sourceRef="gw_skip_phase3"   targetRef="gw_phase3_wait" />

    <bpmn:sequenceFlow id="flow_wait3_to_credit_update"   sourceRef="gw_phase3_wait" targetRef="event_credit_check_update" />
    <bpmn:sequenceFlow id="flow_wait3_to_criminal_update" sourceRef="gw_phase3_wait" targetRef="event_criminal_check_update" />
    <bpmn:sequenceFlow id="flow_wait3_to_refs_update"     sourceRef="gw_phase3_wait" targetRef="event_personal_references_update" />
    <bpmn:sequenceFlow id="flow_credit_update_to_assess"   sourceRef="event_credit_check_update"        targetRef="task_assess_credit_check" />
    <bpmn:sequenceFlow id="flow_criminal_update_to_assess" sourceRef="event_criminal_check_update"      targetRef="task_assess_criminal_check" />
    <bpmn:sequenceFlow id="flow_refs_update_to_assess"     sourceRef="event_personal_references_update" targetRef="task_assess_personal_references" />
    <bpmn:sequenceFlow id="flow_assess_credit_to_continue3"   sourceRef="task_assess_credit_check"        targetRef="gw_phase3_continue" />
    <bpmn:sequenceFlow id="flow_assess_criminal_to_continue3" sourceRef="task_assess_criminal_check"      targetRef="gw_phase3_continue" />
    <bpmn:sequenceFlow id="flow_assess_refs_to_continue3"     sourceRef="task_assess_personal_references" targetRef="gw_phase3_continue" />

    <bpmn:sequenceFlow id="flow_continue3_no_loop"      name="not yet — loop back"
                       sourceRef="gw_phase3_continue" targetRef="gw_phase3_wait" />
    <bpmn:sequenceFlow id="flow_continue3_yes_to_ready" name="all complete"
                       sourceRef="gw_phase3_continue" targetRef="task_mark_ready_for_court" />

    <bpmn:sequenceFlow id="flow_ready_to_end"           sourceRef="task_mark_ready_for_court" targetRef="end" />

  </bpmn:process>

  <!-- BPMN DI: best-effort layout. The diagram is wide (~1900px) and tall
       (~900px) — auto-layout in your modeler is recommended. Phase 2 is
       above the main spine, Phase 3 below. Loop-back edges from the
       continue-gateways route over/under the catch events. -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane id="plane_1" bpmnElement="trusteeship_intended">
      <!-- Main spine, y ≈ 450 -->
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="40" y="432" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_create" bpmnElement="task_create_application">
        <dc:Bounds x="100" y="410" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_initial_assess" bpmnElement="task_assess_initial_state">
        <dc:Bounds x="290" y="410" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_skip_phase2" bpmnElement="gw_skip_phase2" isMarkerVisible="true">
        <dc:Bounds x="500" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_phase2_wait" bpmnElement="gw_phase2_wait">
        <dc:Bounds x="580" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_phase2_continue" bpmnElement="gw_phase2_continue" isMarkerVisible="true">
        <dc:Bounds x="940" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_skip_phase3" bpmnElement="gw_skip_phase3" isMarkerVisible="true">
        <dc:Bounds x="1020" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_phase3_wait" bpmnElement="gw_phase3_wait">
        <dc:Bounds x="1100" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_phase3_continue" bpmnElement="gw_phase3_continue" isMarkerVisible="true">
        <dc:Bounds x="1500" y="425" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_mark_ready" bpmnElement="task_mark_ready_for_court">
        <dc:Bounds x="1580" y="410" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end" bpmnElement="end">
        <dc:Bounds x="1810" y="432" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Phase 2 branches, above the spine -->
      <bpmndi:BPMNShape id="shape_event_app_update" bpmnElement="event_application_update">
        <dc:Bounds x="660" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess_app" bpmnElement="task_assess_application">
        <dc:Bounds x="740" y="200" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_med_update" bpmnElement="event_medical_update">
        <dc:Bounds x="660" y="320" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess_med" bpmnElement="task_assess_medical">
        <dc:Bounds x="740" y="300" width="180" height="80" />
      </bpmndi:BPMNShape>

      <!-- Phase 3 branches, below the spine -->
      <bpmndi:BPMNShape id="shape_event_credit_update" bpmnElement="event_credit_check_update">
        <dc:Bounds x="1180" y="560" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess_credit" bpmnElement="task_assess_credit_check">
        <dc:Bounds x="1260" y="540" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_criminal_update" bpmnElement="event_criminal_check_update">
        <dc:Bounds x="1180" y="660" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess_criminal" bpmnElement="task_assess_criminal_check">
        <dc:Bounds x="1260" y="640" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_refs_update" bpmnElement="event_personal_references_update">
        <dc:Bounds x="1180" y="760" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess_refs" bpmnElement="task_assess_personal_references">
        <dc:Bounds x="1260" y="740" width="220" height="80" />
      </bpmndi:BPMNShape>

      <!-- Spine edges -->
      <bpmndi:BPMNEdge id="edge_start_to_create" bpmnElement="flow_start_to_create">
        <di:waypoint x="76" y="450" /><di:waypoint x="100" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_create_to_initial_assess" bpmnElement="flow_create_to_initial_assess">
        <di:waypoint x="260" y="450" /><di:waypoint x="290" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_initial_assess_to_gw2_skip" bpmnElement="flow_initial_assess_to_gw2_skip">
        <di:waypoint x="470" y="450" /><di:waypoint x="500" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_skip2_yes_to_gw3_skip" bpmnElement="flow_skip2_yes_to_gw3_skip">
        <di:waypoint x="525" y="425" /><di:waypoint x="525" y="380" /><di:waypoint x="1045" y="380" /><di:waypoint x="1045" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_skip2_no_to_wait2" bpmnElement="flow_skip2_no_to_wait2">
        <di:waypoint x="550" y="450" /><di:waypoint x="580" y="450" />
      </bpmndi:BPMNEdge>

      <!-- Phase 2 edges -->
      <bpmndi:BPMNEdge id="edge_wait2_to_app_update" bpmnElement="flow_wait2_to_app_update">
        <di:waypoint x="605" y="425" /><di:waypoint x="605" y="238" /><di:waypoint x="660" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_wait2_to_med_update" bpmnElement="flow_wait2_to_med_update">
        <di:waypoint x="605" y="425" /><di:waypoint x="605" y="338" /><di:waypoint x="660" y="338" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_app_update_to_assess" bpmnElement="flow_app_update_to_assess">
        <di:waypoint x="696" y="238" /><di:waypoint x="740" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_med_update_to_assess" bpmnElement="flow_med_update_to_assess">
        <di:waypoint x="696" y="338" /><di:waypoint x="740" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_assess_app_to_continue2" bpmnElement="flow_assess_app_to_continue2">
        <di:waypoint x="920" y="240" /><di:waypoint x="965" y="240" /><di:waypoint x="965" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_assess_med_to_continue2" bpmnElement="flow_assess_med_to_continue2">
        <di:waypoint x="920" y="340" /><di:waypoint x="965" y="340" /><di:waypoint x="965" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_continue2_no_loop" bpmnElement="flow_continue2_no_loop">
        <di:waypoint x="965" y="425" /><di:waypoint x="965" y="120" /><di:waypoint x="605" y="120" /><di:waypoint x="605" y="425" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_continue2_yes_to_gw3_skip" bpmnElement="flow_continue2_yes_to_gw3_skip">
        <di:waypoint x="990" y="450" /><di:waypoint x="1020" y="450" />
      </bpmndi:BPMNEdge>

      <!-- Spine continuation -->
      <bpmndi:BPMNEdge id="edge_skip3_yes_to_ready" bpmnElement="flow_skip3_yes_to_ready">
        <di:waypoint x="1045" y="425" /><di:waypoint x="1045" y="380" /><di:waypoint x="1680" y="380" /><di:waypoint x="1680" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_skip3_no_to_wait3" bpmnElement="flow_skip3_no_to_wait3">
        <di:waypoint x="1070" y="450" /><di:waypoint x="1100" y="450" />
      </bpmndi:BPMNEdge>

      <!-- Phase 3 edges -->
      <bpmndi:BPMNEdge id="edge_wait3_to_credit_update" bpmnElement="flow_wait3_to_credit_update">
        <di:waypoint x="1125" y="475" /><di:waypoint x="1125" y="578" /><di:waypoint x="1180" y="578" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_wait3_to_criminal_update" bpmnElement="flow_wait3_to_criminal_update">
        <di:waypoint x="1125" y="475" /><di:waypoint x="1125" y="678" /><di:waypoint x="1180" y="678" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_wait3_to_refs_update" bpmnElement="flow_wait3_to_refs_update">
        <di:waypoint x="1125" y="475" /><di:waypoint x="1125" y="778" /><di:waypoint x="1180" y="778" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_credit_update_to_assess" bpmnElement="flow_credit_update_to_assess">
        <di:waypoint x="1216" y="578" /><di:waypoint x="1260" y="580" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_criminal_update_to_assess" bpmnElement="flow_criminal_update_to_assess">
