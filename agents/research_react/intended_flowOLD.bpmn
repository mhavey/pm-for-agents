<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_research_react_intended"
    targetNamespace="http://tmls2026/research-react">

  <bpmn:process id="research_react_intended"
                name="research_react — intended per-turn flow"
                isExecutable="false">

    <bpmn:documentation>
      Intended per-turn flow for the research_react agent. Each user turn
      starts at "User message received" and ends at "Response delivered".
      Activities are the four tools the agent has at its disposal; gateways
      represent the decisions the model is supposed to make per the system
      prompt (agents/research_react/src/system_prompt.md). This BPMN is the
      reference model for process-mining conformance checks against the XES
      log produced by process_mining/xray_to_xes.py.

      Note: analyze_full_article is reachable ONLY via the "deep-analysis
      confirmed" intent branch — encoding the prompt's rule that the tool
      must never be invoked on the agent's own initiative. Any trace where
      analyze_full_article is preceded by anything else is nonconforming.
    </bpmn:documentation>

    <!-- ===== Start ===== -->
    <bpmn:startEvent id="start" name="User message received">
      <bpmn:outgoing>flow_start_to_intent</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ===== Intent classification ===== -->
    <bpmn:exclusiveGateway id="gw_intent" name="Classify intent">
      <bpmn:incoming>flow_start_to_intent</bpmn:incoming>
      <bpmn:outgoing>flow_intent_topic</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_browse</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_deep</bpmn:outgoing>
      <bpmn:outgoing>flow_intent_decline</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ===== Topic-similarity branch ===== -->
    <bpmn:serviceTask id="task_find_similar" name="find_similar_articles">
      <bpmn:documentation>Tool call: hybrid retrieval over the arXiv KB,
        with optional category/date prefilters from the user's query.</bpmn:documentation>
      <bpmn:incoming>flow_intent_topic</bpmn:incoming>
      <bpmn:outgoing>flow_after_search</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="gw_hits" name="Relevant hits?">
      <bpmn:incoming>flow_after_search</bpmn:incoming>
      <bpmn:outgoing>flow_hits_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_hits_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="task_web_search" name="web_search">
      <bpmn:documentation>Fallback tool call: DuckDuckGo search, used only
        when find_similar_articles returned nothing relevant.</bpmn:documentation>
      <bpmn:incoming>flow_hits_no</bpmn:incoming>
      <bpmn:outgoing>flow_after_web</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== Browse branch ===== -->
    <bpmn:serviceTask id="task_sample_articles" name="sample_articles">
      <bpmn:documentation>Tool call: random sample with optional
        category/date filters. Used for browsing without a topic.</bpmn:documentation>
      <bpmn:incoming>flow_intent_browse</bpmn:incoming>
      <bpmn:outgoing>flow_after_browse</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== Deep-analysis branch ===== -->
    <!-- Reached only when the prior turn ended with a consent question
         and the user replied affirmatively. -->
    <bpmn:serviceTask id="task_analyze_full" name="analyze_full_article">
      <bpmn:documentation>Tool call: download arXiv PDF and run an extended
        summary. EXPENSIVE; reachable ONLY when the user has confirmed in
        a prior turn. The tool itself enforces user_confirmed=True as a
        runtime safety net.</bpmn:documentation>
      <bpmn:incoming>flow_intent_deep</bpmn:incoming>
      <bpmn:outgoing>flow_after_deep</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== Join + compose + end ===== -->
    <bpmn:exclusiveGateway id="gw_join" name="Converge">
      <bpmn:incoming>flow_hits_yes</bpmn:incoming>
      <bpmn:incoming>flow_after_web</bpmn:incoming>
      <bpmn:incoming>flow_after_browse</bpmn:incoming>
      <bpmn:incoming>flow_after_deep</bpmn:incoming>
      <bpmn:incoming>flow_intent_decline</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_compose</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_compose" name="Compose response">
      <bpmn:documentation>Synthesize the final user-facing reply from
        whatever the prior step produced. If the retrieval surfaced a paper
        warranting deep analysis and the user has not yet been asked, the
        reply ends with a yes/no consent question. That question is just
        text — the actual deep call happens on the NEXT turn via the
        "deep-analysis confirmed" intent branch.</bpmn:documentation>
      <bpmn:incoming>flow_join_to_compose</bpmn:incoming>
      <bpmn:outgoing>flow_compose_to_end</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_response" name="Response delivered">
      <bpmn:incoming>flow_compose_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ===== Sequence flows ===== -->
    <bpmn:sequenceFlow id="flow_start_to_intent" sourceRef="start" targetRef="gw_intent" />

    <bpmn:sequenceFlow id="flow_intent_topic"   name="topic similarity"
                       sourceRef="gw_intent" targetRef="task_find_similar" />
    <bpmn:sequenceFlow id="flow_intent_browse"  name="browse / discovery"
                       sourceRef="gw_intent" targetRef="task_sample_articles" />
    <bpmn:sequenceFlow id="flow_intent_deep"    name="deep-analysis confirmed (prior consent)"
                       sourceRef="gw_intent" targetRef="task_analyze_full" />
    <bpmn:sequenceFlow id="flow_intent_decline" name="conversational / no retrieval"
                       sourceRef="gw_intent" targetRef="gw_join" />

    <bpmn:sequenceFlow id="flow_after_search" sourceRef="task_find_similar" targetRef="gw_hits" />
    <bpmn:sequenceFlow id="flow_hits_yes" name="relevant"           sourceRef="gw_hits" targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_hits_no"  name="poor / off-topic"   sourceRef="gw_hits" targetRef="task_web_search" />

    <bpmn:sequenceFlow id="flow_after_web"    sourceRef="task_web_search"      targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_after_browse" sourceRef="task_sample_articles" targetRef="gw_join" />
    <bpmn:sequenceFlow id="flow_after_deep"   sourceRef="task_analyze_full"    targetRef="gw_join" />

    <bpmn:sequenceFlow id="flow_join_to_compose" sourceRef="gw_join"      targetRef="task_compose" />
    <bpmn:sequenceFlow id="flow_compose_to_end"  sourceRef="task_compose" targetRef="end_response" />

  </bpmn:process>

  <!-- BPMN DI: minimal layout so the file renders in BPMN modelers
       (bpmn.io, Camunda Modeler, etc.). Auto-layout will tidy this. -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane id="plane_1" bpmnElement="research_react_intended">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="100" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_intent" bpmnElement="gw_intent" isMarkerVisible="true">
        <dc:Bounds x="200" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_find_similar" bpmnElement="task_find_similar">
        <dc:Bounds x="320" y="80" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_hits" bpmnElement="gw_hits" isMarkerVisible="true">
        <dc:Bounds x="510" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_web_search" bpmnElement="task_web_search">
        <dc:Bounds x="620" y="80" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_sample_articles" bpmnElement="task_sample_articles">
        <dc:Bounds x="320" y="200" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_analyze_full" bpmnElement="task_analyze_full">
        <dc:Bounds x="320" y="340" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_join" bpmnElement="gw_join" isMarkerVisible="true">
        <dc:Bounds x="800" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_compose" bpmnElement="task_compose">
        <dc:Bounds x="900" y="260" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_response" bpmnElement="end_response">
        <dc:Bounds x="1080" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_flow_start_to_intent" bpmnElement="flow_start_to_intent">
        <di:waypoint x="136" y="300" />
        <di:waypoint x="200" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_topic" bpmnElement="flow_intent_topic">
        <di:waypoint x="225" y="275" />
        <di:waypoint x="225" y="120" />
        <di:waypoint x="320" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_browse" bpmnElement="flow_intent_browse">
        <di:waypoint x="250" y="300" />
        <di:waypoint x="320" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_deep" bpmnElement="flow_intent_deep">
        <di:waypoint x="225" y="325" />
        <di:waypoint x="225" y="380" />
        <di:waypoint x="320" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_intent_decline" bpmnElement="flow_intent_decline">
        <di:waypoint x="250" y="300" />
        <di:waypoint x="800" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_search" bpmnElement="flow_after_search">
        <di:waypoint x="460" y="120" />
        <di:waypoint x="510" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_hits_yes" bpmnElement="flow_hits_yes">
        <di:waypoint x="535" y="145" />
        <di:waypoint x="535" y="220" />
        <di:waypoint x="800" y="220" />
        <di:waypoint x="825" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_hits_no" bpmnElement="flow_hits_no">
        <di:waypoint x="560" y="120" />
        <di:waypoint x="620" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_web" bpmnElement="flow_after_web">
        <di:waypoint x="740" y="120" />
        <di:waypoint x="825" y="275" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_browse" bpmnElement="flow_after_browse">
        <di:waypoint x="460" y="240" />
        <di:waypoint x="800" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_after_deep" bpmnElement="flow_after_deep">
        <di:waypoint x="460" y="380" />
        <di:waypoint x="825" y="325" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_join_to_compose" bpmnElement="flow_join_to_compose">
        <di:waypoint x="850" y="300" />
        <di:waypoint x="900" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_compose_to_end" bpmnElement="flow_compose_to_end">
        <di:waypoint x="1020" y="300" />
        <di:waypoint x="1080" y="300" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
