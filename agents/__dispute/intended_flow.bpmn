<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    id="Definitions_dispute_intended"
    targetNamespace="http://tmls2026/dispute">

  <bpmn:process id="dispute_intended"
                name="Credit-card dispute — main structure"
                isExecutable="false">

    <bpmn:documentation>
      Dispute lifecycle BPMN, MAIN STRUCTURE ONLY. The customer files a dispute
      (CustCreate), the system records it (CreateDispute), the AI makes an
      initial readiness assessment (AIAssessDisputeReadiness), and the case
      then enters an event-driven loop. Seven external events can arrive while
      the case is in the loop:

        - CustUpdate                      (customer provides more info)
        - CustCancel                      (customer withdraws)
        - OpsReject                       (ops rejects the dispute)
        - OpsWriteoff                     (ops writes it off)
        - OpsReviewApproved               (ops approves the customer's claim)
        - OpsReviewCustFeedbackNeeded     (ops needs further customer input)
        - OpsReviewArbitrationNeeded      (escalation to network arbitration)

      For this iteration, each catch event loops back to the event-loop gateway
      without an explicit handler. Per-event actions, terminal end events, and
      any context-dependent guards on which events are valid in a given state
      will be added in subsequent iterations.

      Each external event arrives as its own AgentCore invocation / X-Ray trace.
      The BPMN models the full case lifecycle; per-invocation conformance will
      require case_id = dispute_id (documented next step in xray_to_xes).
    </bpmn:documentation>

    <!-- ===== Initial event: customer creates the dispute ===== -->
    <bpmn:startEvent id="start" name="CustCreate">
      <bpmn:outgoing>flow_start_to_create</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:startEvent>

    <!-- ===== System task: record the dispute ===== -->
    <bpmn:serviceTask id="task_create_dispute" name="CreateDispute">
      <bpmn:documentation>Persist the new dispute case to DynamoDB.
        Manually-instrumented OTel span at the entrypoint plumbing layer
        (only on the first invocation).</bpmn:documentation>
      <bpmn:incoming>flow_start_to_create</bpmn:incoming>
      <bpmn:outgoing>flow_create_to_assess</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== System task: AI readiness assessment ===== -->
    <bpmn:serviceTask id="task_ai_assess_readiness" name="AIAssessDisputeReadiness">
      <bpmn:documentation>The AI agent inspects the newly-created case and
        decides its initial state — that state determines which events are
        valid in the subsequent loop and how each is handled. Manually-
        instrumented OTel span at the entrypoint plumbing layer.</bpmn:documentation>
      <bpmn:incoming>flow_create_to_assess</bpmn:incoming>
      <bpmn:outgoing>flow_assess_to_loop</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ===== Event loop gateway ===== -->
    <bpmn:eventBasedGateway id="gw_event_loop" name="Event loop">
      <bpmn:documentation>Park the case here until one of seven external
        events arrives. Each event arrives as a separate AgentCore
        invocation; the entrypoint reads event.type and the agent
        dispatches accordingly. Per-event actions are TBD — the loop-back
        edges from each catch event back to this gateway are the placeholder.</bpmn:documentation>
      <bpmn:incoming>flow_assess_to_loop</bpmn:incoming>
      <bpmn:incoming>flow_cust_update_back</bpmn:incoming>
      <bpmn:incoming>flow_cust_cancel_back</bpmn:incoming>
      <bpmn:incoming>flow_ops_reject_back</bpmn:incoming>
      <bpmn:incoming>flow_ops_writeoff_back</bpmn:incoming>
      <bpmn:incoming>flow_ops_review_approved_back</bpmn:incoming>
      <bpmn:incoming>flow_ops_review_cust_feedback_back</bpmn:incoming>
      <bpmn:incoming>flow_ops_review_arbitration_back</bpmn:incoming>
      <bpmn:outgoing>flow_to_cust_update</bpmn:outgoing>
      <bpmn:outgoing>flow_to_cust_cancel</bpmn:outgoing>
      <bpmn:outgoing>flow_to_ops_reject</bpmn:outgoing>
      <bpmn:outgoing>flow_to_ops_writeoff</bpmn:outgoing>
      <bpmn:outgoing>flow_to_ops_review_approved</bpmn:outgoing>
      <bpmn:outgoing>flow_to_ops_review_cust_feedback</bpmn:outgoing>
      <bpmn:outgoing>flow_to_ops_review_arbitration</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <!-- ===== Catch events ===== -->
    <bpmn:intermediateCatchEvent id="event_cust_update" name="CustUpdate">
      <bpmn:incoming>flow_to_cust_update</bpmn:incoming>
      <bpmn:outgoing>flow_cust_update_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_cust_cancel" name="CustCancel">
      <bpmn:incoming>flow_to_cust_cancel</bpmn:incoming>
      <bpmn:outgoing>flow_cust_cancel_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_ops_reject" name="OpsReject">
      <bpmn:incoming>flow_to_ops_reject</bpmn:incoming>
      <bpmn:outgoing>flow_ops_reject_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_ops_writeoff" name="OpsWriteoff">
      <bpmn:incoming>flow_to_ops_writeoff</bpmn:incoming>
      <bpmn:outgoing>flow_ops_writeoff_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_ops_review_approved" name="OpsReviewApproved">
      <bpmn:incoming>flow_to_ops_review_approved</bpmn:incoming>
      <bpmn:outgoing>flow_ops_review_approved_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_ops_review_cust_feedback" name="OpsReviewCustFeedbackNeeded">
      <bpmn:incoming>flow_to_ops_review_cust_feedback</bpmn:incoming>
      <bpmn:outgoing>flow_ops_review_cust_feedback_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event_ops_review_arbitration" name="OpsReviewArbitrationNeeded">
      <bpmn:incoming>flow_to_ops_review_arbitration</bpmn:incoming>
      <bpmn:outgoing>flow_ops_review_arbitration_back</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>

    <!-- ===== Sequence flows: main spine ===== -->
    <bpmn:sequenceFlow id="flow_start_to_create"  sourceRef="start"                    targetRef="task_create_dispute" />
    <bpmn:sequenceFlow id="flow_create_to_assess" sourceRef="task_create_dispute"      targetRef="task_ai_assess_readiness" />
    <bpmn:sequenceFlow id="flow_assess_to_loop"   sourceRef="task_ai_assess_readiness" targetRef="gw_event_loop" />

    <!-- ===== Sequence flows: gateway → catch events ===== -->
    <bpmn:sequenceFlow id="flow_to_cust_update"               sourceRef="gw_event_loop" targetRef="event_cust_update" />
    <bpmn:sequenceFlow id="flow_to_cust_cancel"               sourceRef="gw_event_loop" targetRef="event_cust_cancel" />
    <bpmn:sequenceFlow id="flow_to_ops_reject"                sourceRef="gw_event_loop" targetRef="event_ops_reject" />
    <bpmn:sequenceFlow id="flow_to_ops_writeoff"              sourceRef="gw_event_loop" targetRef="event_ops_writeoff" />
    <bpmn:sequenceFlow id="flow_to_ops_review_approved"       sourceRef="gw_event_loop" targetRef="event_ops_review_approved" />
    <bpmn:sequenceFlow id="flow_to_ops_review_cust_feedback"  sourceRef="gw_event_loop" targetRef="event_ops_review_cust_feedback" />
    <bpmn:sequenceFlow id="flow_to_ops_review_arbitration"    sourceRef="gw_event_loop" targetRef="event_ops_review_arbitration" />

    <!-- ===== Sequence flows: catch events → back to gateway (placeholders) ===== -->
    <bpmn:sequenceFlow id="flow_cust_update_back"              sourceRef="event_cust_update"              targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_cust_cancel_back"              sourceRef="event_cust_cancel"              targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_ops_reject_back"               sourceRef="event_ops_reject"               targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_ops_writeoff_back"             sourceRef="event_ops_writeoff"             targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_ops_review_approved_back"      sourceRef="event_ops_review_approved"      targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_ops_review_cust_feedback_back" sourceRef="event_ops_review_cust_feedback" targetRef="gw_event_loop" />
    <bpmn:sequenceFlow id="flow_ops_review_arbitration_back"   sourceRef="event_ops_review_arbitration"   targetRef="gw_event_loop" />

  </bpmn:process>

  <!-- BPMN DI: best-effort. Main spine left-to-right; catch events stacked
       vertically to the right of the gateway. -->
  <bpmndi:BPMNDiagram id="diagram_1">
    <bpmndi:BPMNPlane id="plane_1" bpmnElement="dispute_intended">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="60" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_create" bpmnElement="task_create_dispute">
        <dc:Bounds x="140" y="340" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_assess" bpmnElement="task_ai_assess_readiness">
        <dc:Bounds x="320" y="340" width="200" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_event_loop" bpmnElement="gw_event_loop">
        <dc:Bounds x="570" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_event_cust_update" bpmnElement="event_cust_update">
        <dc:Bounds x="720"  y="40"  width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_cust_cancel" bpmnElement="event_cust_cancel">
        <dc:Bounds x="720"  y="140" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_ops_reject" bpmnElement="event_ops_reject">
        <dc:Bounds x="720"  y="240" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_ops_writeoff" bpmnElement="event_ops_writeoff">
        <dc:Bounds x="720"  y="362" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_ops_review_approved" bpmnElement="event_ops_review_approved">
        <dc:Bounds x="720"  y="480" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_ops_review_cust_feedback" bpmnElement="event_ops_review_cust_feedback">
        <dc:Bounds x="720"  y="600" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_event_ops_review_arbitration" bpmnElement="event_ops_review_arbitration">
        <dc:Bounds x="720"  y="720" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Main spine edges -->
      <bpmndi:BPMNEdge id="edge_flow_start_to_create" bpmnElement="flow_start_to_create">
        <di:waypoint x="96" y="380" /><di:waypoint x="140" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_create_to_assess" bpmnElement="flow_create_to_assess">
        <di:waypoint x="280" y="380" /><di:waypoint x="320" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_assess_to_loop" bpmnElement="flow_assess_to_loop">
        <di:waypoint x="520" y="380" /><di:waypoint x="570" y="380" />
      </bpmndi:BPMNEdge>

      <!-- Gateway → catch events (fan out) -->
      <bpmndi:BPMNEdge id="edge_flow_to_cust_update" bpmnElement="flow_to_cust_update">
        <di:waypoint x="595" y="355" /><di:waypoint x="595" y="58" /><di:waypoint x="720" y="58" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_cust_cancel" bpmnElement="flow_to_cust_cancel">
        <di:waypoint x="595" y="355" /><di:waypoint x="595" y="158" /><di:waypoint x="720" y="158" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_ops_reject" bpmnElement="flow_to_ops_reject">
        <di:waypoint x="595" y="355" /><di:waypoint x="595" y="258" /><di:waypoint x="720" y="258" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_ops_writeoff" bpmnElement="flow_to_ops_writeoff">
        <di:waypoint x="620" y="380" /><di:waypoint x="720" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_ops_review_approved" bpmnElement="flow_to_ops_review_approved">
        <di:waypoint x="595" y="405" /><di:waypoint x="595" y="498" /><di:waypoint x="720" y="498" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_ops_review_cust_feedback" bpmnElement="flow_to_ops_review_cust_feedback">
        <di:waypoint x="595" y="405" /><di:waypoint x="595" y="618" /><di:waypoint x="720" y="618" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_ops_review_arbitration" bpmnElement="flow_to_ops_review_arbitration">
        <di:waypoint x="595" y="405" /><di:waypoint x="595" y="738" /><di:waypoint x="720" y="738" />
      </bpmndi:BPMNEdge>

      <!-- Catch events → loop back (placeholder; actions to come) -->
      <bpmndi:BPMNEdge id="edge_flow_cust_update_back" bpmnElement="flow_cust_update_back">
        <di:waypoint x="756" y="58" /><di:waypoint x="800" y="58" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_cust_cancel_back" bpmnElement="flow_cust_cancel_back">
        <di:waypoint x="756" y="158" /><di:waypoint x="800" y="158" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ops_reject_back" bpmnElement="flow_ops_reject_back">
        <di:waypoint x="756" y="258" /><di:waypoint x="800" y="258" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ops_writeoff_back" bpmnElement="flow_ops_writeoff_back">
        <di:waypoint x="756" y="380" /><di:waypoint x="800" y="380" /><di:waypoint x="800" y="430" /><di:waypoint x="620" y="430" /><di:waypoint x="620" y="405" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ops_review_approved_back" bpmnElement="flow_ops_review_approved_back">
        <di:waypoint x="756" y="498" /><di:waypoint x="800" y="498" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ops_review_cust_feedback_back" bpmnElement="flow_ops_review_cust_feedback_back">
        <di:waypoint x="756" y="618" /><di:waypoint x="800" y="618" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ops_review_arbitration_back" bpmnElement="flow_ops_review_arbitration_back">
        <di:waypoint x="756" y="738" /><di:waypoint x="800" y="738" /><di:waypoint x="800" y="380" /><di:waypoint x="620" y="380" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
